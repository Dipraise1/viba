{
  "expo": {
    "name": "Viba",
    "slug": "viba",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "backgroundColor": "#05050F"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.viba.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0A0A12"
      },
      "package": "com.viba.app"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-camera",
        {
          "cameraPermission": "Viba needs camera access to broadcast your live stream.",
          "microphonePermission": "Viba needs microphone access to include audio in your live stream.",
          "recordAudioAndroid": true
        }
      ],
      "expo-web-browser",
      "expo-secure-store",
      "expo-apple-authentication",
      [
        "expo-image-picker",
        {
          "photosPermission": "Viba needs access to your photos to set a profile picture."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#FF2D87",
          "sounds": []
        }
      ]
    ],
    "scheme": "viba",
    "experiments": {
      "typedRoutes": true
    }
  }
}
